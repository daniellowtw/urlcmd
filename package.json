{
  "name": "urlcmd",
  "version": "1.0.0",
  "private": true,
  "description": "URL command bar — type commands and aliases into the browser URL bar",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "build": "tsc && bun build ./src/main.ts --minify --format iife --outfile js/main.js",
    "check": "tsc",
    "test": "bun run build && bun test"
  },
  "devDependencies": {
    "typescript": "7.0.2"
  }
}
